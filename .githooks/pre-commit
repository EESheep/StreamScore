#!/usr/bin/env bash
# ============================================================
# StreamScore Pre-Commit Hook — 密钥泄露扫描
# 阻止提交包含疑似 API Key / Token 的内容
# ============================================================
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FOUND_SECRET=false
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

TEXT_FILES=()
for f in $STAGED_FILES; do
    # 跳过 hooks 自身和 scripts 目录
    case "$f" in
        .githooks/*|scripts/*) continue ;;
    esac
    if [ -f "$f" ]; then
        ext="${f##*.}"
        case "$ext" in
            py|yaml|yml|json|txt|md|sh|toml|cfg|ini|env|js|ts|html|css|bat|ps1)
                TEXT_FILES+=("$f") ;;
            *)
                if file "$f" 2>/dev/null | grep -qi 'text'; then
                    TEXT_FILES+=("$f")
                fi
                ;;
        esac
    fi
done

if [ ${#TEXT_FILES[@]} -eq 0 ]; then
    exit 0
fi

# ============================================================
# 检测函数
# ============================================================
scan_file() {
    local file="$1"
    local content
    content=$(git show ":${file}" 2>/dev/null) || return

    local line_num=0
    while IFS= read -r line; do
        line_num=$((line_num + 1))

        # 跳过纯注释行
        [[ "$line" =~ ^[[:space:]]*# ]] && continue

        # --- 规则 1: OpenAI / DeepSeek 风格 key (sk- 开头) ---
        if echo "$line" | grep -qE "sk-[A-Za-z0-9_-]{20,}"; then
            if ! echo "$line" | grep -qiE 'your.api.key|your-api-key|sk-your|sk-xxxx|placeholder|replace|change_me|example'; then
                printf "${RED}[SECRET]${NC} %s:%s -> suspected API Key (sk-...)\n" "$file" "$line_num"
                printf "          %s\n" "$line"
                FOUND_SECRET=true
            fi
        fi

        # --- 规则 2: HuggingFace token (hf_ 开头) ---
        if echo "$line" | grep -qE "hf_[A-Za-z0-9]{20,}"; then
            if ! echo "$line" | grep -qiE 'your.token|hf_xxxx|hf_your|placeholder|replace|change_me|example|hf_token'; then
                printf "${RED}[SECRET]${NC} %s:%s -> suspected HuggingFace Token (hf_...)\n" "$file" "$line_num"
                printf "          %s\n" "$line"
                FOUND_SECRET=true
            fi
        fi

        # --- 规则 3: 通用 api_key 字段带长值 ---
        if echo "$line" | grep -qiE '(api_key|apikey|api_secret|secret_key)[[:space:]]*[:=][[:space:]]*"[A-Za-z0-9_\-]{20,}"'; then
            if ! echo "$line" | grep -qiE 'your.api.key|your-api-key|sk-your|placeholder|replace|change_me|example|xxx|xxxx'; then
                printf "${RED}[SECRET]${NC} %s:%s -> suspected hardcoded API Key\n" "$file" "$line_num"
                printf "          %s\n" "$line"
                FOUND_SECRET=true
            fi
        fi

        # --- 规则 4: 私钥 ---
        if echo "$line" | grep -qE 'BEGIN (RSA|EC|DSA|OPENSSH|PGP) PRIVATE KEY'; then
            printf "${RED}[SECRET]${NC} %s:%s -> private key block\n" "$file" "$line_num"
            printf "          %s\n" "$line"
            FOUND_SECRET=true
        fi

        # --- 规则 5: 高熵长字符串（疑似 token）---
        local b64_tokens
        b64_tokens=$(echo "$line" | grep -oE '[A-Za-z0-9+/=]{40,}' || true)
        if [ -n "$b64_tokens" ]; then
            for token in $b64_tokens; do
                if [ ${#token} -ge 40 ]; then
                    # 排除纯分隔符重复行 (======, -------- 等)
                    if echo "$token" | grep -qE '^(.)\1{10,}$'; then
                        continue
                    fi
                    if ! echo "$line" | grep -qiE 'sha256|md5|hash|checksum|etag|base64_decode|atob|byte|bytes'; then
                        printf "${YELLOW}[WARN]${NC}  %s:%s -> high-entropy string, verify not a token\n" "$file" "$line_num"
                        printf "          ...%s...\n" "${token:0:20}"
                        FOUND_SECRET=true
                    fi
                fi
            done
        fi
    done <<< "$content"
}

echo "Scanning for secrets in staged files..."
for f in "${TEXT_FILES[@]}"; do
    scan_file "$f"
done

if $FOUND_SECRET; then
    echo ""
    echo "============================================"
    echo "  COMMIT BLOCKED: suspected secret leak"
    echo "============================================"
    echo ""
    echo "Review the lines flagged above. If these are real API keys/tokens,"
    echo "replace them with placeholders (e.g. sk-your-api-key) before committing."
    echo ""
    echo "If confirmed safe (false positive), bypass with:"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
